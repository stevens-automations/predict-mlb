{
  "contract": {
    "name": "pregame_1h",
    "target": "home_team_win_probability",
    "label_column": "did_home_win",
    "feature_version": "v2_phase1",
    "sportsbook_odds_as_features": false
  },
  "experiment": {
    "name": "stronger_pregame_1h_v2_phase1_hybrid_comparative"
  },
  "data": {
    "db_path": "data/mlb_history.db",
    "feature_version": "v2_phase1",
    "feature_contract": "hybrid_comparative_v1",
    "seasons": [2020, 2021, 2022, 2023, 2024, 2025],
    "contract_statuses": [
      "valid",
      "degraded"
    ]
  },
  "evaluation": {
    "seasonal_holdout": {
      "development_seasons": [2020, 2021, 2022, 2023, 2024],
      "holdout_season": 2025,
      "min_train_seasons": 2
    }
  },
  "model": {
    "trainer": "lgbm",
    "name": "lgbm_stronger_hybrid_comparative",
    "params": {
      "objective": "binary",
      "metric": "binary_logloss",
      "learning_rate": 0.03,
      "num_leaves": 63,
      "feature_fraction": 0.85,
      "bagging_fraction": 0.85,
      "bagging_freq": 1,
      "min_data_in_leaf": 25,
      "lambda_l1": 0.5,
      "lambda_l2": 0.5,
      "verbose": -1,
      "num_boost_round": 500
    }
  },
  "registry": {
    "root_dir": "artifacts/model_registry"
  }
}
