{
  "base": {
    "data": {
      "db_path": "data/mlb_history.db",
      "seasons": [2020, 2021, 2022, 2023, 2024, 2025],
      "feature_version": "v1",
      "contract_statuses": ["valid", "degraded"]
    },
    "evaluation": {
      "walk_forward": {
        "min_train_samples": 1500,
        "test_size": 300,
        "step_size": 300,
        "gap": 0
      }
    },
    "registry": {
      "root_dir": "artifacts/model_registry"
    }
  },
  "experiments": [
    {
      "experiment": {
        "name": "baseline_walk_forward_v1"
      },
      "model": {
        "name": "lgbm_baseline",
        "trainer": "lgbm",
        "params": {
          "objective": "binary",
          "metric": "binary_logloss",
          "learning_rate": 0.03,
          "num_leaves": 31,
          "min_data_in_leaf": 60,
          "feature_fraction": 0.9,
          "bagging_fraction": 0.9,
          "bagging_freq": 1,
          "lambda_l2": 1.0,
          "verbosity": -1,
          "seed": 20260309,
          "num_boost_round": 350
        }
      }
    },
    {
      "experiment": {
        "name": "tuned_candidate_v1"
      },
      "model": {
        "name": "lgbm_tuned_candidate",
        "trainer": "lgbm",
        "params": {
          "objective": "binary",
          "metric": "binary_logloss",
          "learning_rate": 0.02,
          "num_leaves": 15,
          "min_data_in_leaf": 120,
          "feature_fraction": 0.8,
          "bagging_fraction": 0.75,
          "bagging_freq": 1,
          "lambda_l1": 0.5,
          "lambda_l2": 2.0,
          "min_gain_to_split": 0.02,
          "verbosity": -1,
          "seed": 20260309,
          "num_boost_round": 500
        }
      }
    },
    {
      "experiment": {
        "name": "ensemble_candidate_placeholder_v1"
      },
      "execution": {
        "enabled": false,
        "reason": "Do not run until the calibrated single-model challenger consistently clears promotion gates."
      },
      "model": {
        "name": "ensemble_candidate_placeholder",
        "trainer": "lgbm",
        "params": {
          "objective": "binary",
          "metric": "binary_logloss",
          "learning_rate": 0.03,
          "num_leaves": 31,
          "verbosity": -1,
          "seed": 20260309,
          "num_boost_round": 350
        }
      }
    }
  ]
}
