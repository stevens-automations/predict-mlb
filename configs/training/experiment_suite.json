{
  "base": {
    "contract": {
      "name": "pregame_1h",
      "target": "home_team_win_probability",
      "label_column": "did_home_win",
      "feature_version": "v2_phase1",
      "sportsbook_odds_as_features": false
    },
    "data": {
      "db_path": "data/mlb_history.db",
      "seasons": [2020, 2021, 2022, 2023, 2024, 2025],
      "feature_version": "v2_phase1",
      "contract_statuses": ["valid", "degraded"]
    },
    "evaluation": {
      "seasonal_holdout": {
        "development_seasons": [2020, 2021, 2022, 2023, 2024],
        "holdout_season": 2025,
        "min_train_seasons": 2
      }
    },
    "registry": {
      "root_dir": "artifacts/model_registry"
    }
  },
  "experiments": [
    {
      "experiment": {
        "name": "baseline_pregame_1h_v2_phase1_lgbm"
      },
      "model": {
        "name": "lgbm_baseline",
        "trainer": "lgbm",
        "params": {
          "objective": "binary",
          "metric": "binary_logloss",
          "learning_rate": 0.03,
          "num_leaves": 31,
          "min_data_in_leaf": 60,
          "feature_fraction": 0.9,
          "bagging_fraction": 0.9,
          "bagging_freq": 1,
          "lambda_l2": 1.0,
          "verbosity": -1,
          "seed": 20260309,
          "num_boost_round": 350
        }
      }
    },
    {
      "experiment": {
        "name": "tuned_candidate_pregame_1h_v2_phase1"
      },
      "model": {
        "name": "lgbm_tuned_candidate",
        "trainer": "lgbm",
        "params": {
          "objective": "binary",
          "metric": "binary_logloss",
          "learning_rate": 0.02,
          "num_leaves": 15,
          "min_data_in_leaf": 120,
          "feature_fraction": 0.8,
          "bagging_fraction": 0.75,
          "bagging_freq": 1,
          "lambda_l1": 0.5,
          "lambda_l2": 2.0,
          "min_gain_to_split": 0.02,
          "verbosity": -1,
          "seed": 20260309,
          "num_boost_round": 500
        }
      }
    },
    {
      "experiment": {
        "name": "benchmark_pregame_1h_v2_phase1_logreg"
      },
      "model": {
        "name": "logreg_benchmark",
        "trainer": "logreg",
        "params": {
          "C": 1.0,
          "penalty": "l2",
          "class_weight": "balanced",
          "max_iter": 2000,
          "solver": "lbfgs",
          "random_state": 20260312
        }
      }
    },
    {
      "experiment": {
        "name": "ensemble_candidate_placeholder_pregame_1h_v2_phase1"
      },
      "execution": {
        "enabled": false,
        "reason": "Do not run until the calibrated single-model challenger consistently clears promotion gates."
      },
      "model": {
        "name": "ensemble_candidate_placeholder",
        "trainer": "lgbm",
        "params": {
          "objective": "binary",
          "metric": "binary_logloss",
          "learning_rate": 0.03,
          "num_leaves": 31,
          "verbosity": -1,
          "seed": 20260309,
          "num_boost_round": 350
        }
      }
    }
  ]
}
